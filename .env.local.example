# ─── Supabase ───────────────────────────────────────────────
# Creá tu proyecto gratis en https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://XXXXXXXXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
SUPABASE_SERVICE_ROLE_KEY=eyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── Gmail ──────────────────────────────────────────────────
# Usá una "App Password" de Google (no tu contraseña normal)
# Ver instrucciones en README.md
GMAIL_USER=tu-email@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ─── Config general ─────────────────────────────────────────
# El email que recibirá las alertas (puede ser el mismo Gmail)
ALERT_EMAIL_TO=tu-email@gmail.com

# Clave secreta para proteger el endpoint /api/cron
# Ponele cualquier texto largo y random
CRON_SECRET=cambia-esto-por-algo-secreto-largo
